TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
REPLICATE_API_TOKEN=your_replicate_api_token_here
XAI_API_KEY=your_xai_api_key_here
REPLICATE_MODEL=xai/grok-imagine-image-quality

# Optional: comma-separated Telegram user IDs allowed to use the bot (empty = all users)
# ALLOWED_TELEGRAM_IDS=123456789,987654321

# Optional: max concurrent video jobs across all users (default: 5)
# VIDEO_MAX_GLOBAL_CONCURRENT=5

# Optional: max video API jobs per hour across all users (default: 50)
# VIDEO_MAX_GLOBAL_HOURLY=50
